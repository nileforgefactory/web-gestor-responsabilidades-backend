# Copiar a .env para desarrollo local (fuera de Docker) o personalizar Compose.



APP_ENV=dev

APP_HOST=0.0.0.0

APP_PORT=8000



QDRANT_URL=http://localhost:6333

QDRANT_COLLECTION=rag_chunks

VECTOR_SIZE=768



USE_OLLAMA=true

OLLAMA_BASE_URL=http://localhost:11434

OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# En máquinas con poca RAM usar: llama3.2:3b

OLLAMA_CHAT_MODEL=llama3.1:8b

# GPU (solo con docker-compose.gpu.yml): ver docs/OLLAMA_GPU.md

# OLLAMA_NUM_PARALLEL=2

# OLLAMA_MAX_LOADED_MODELS=1



INGEST_EMBED_CONCURRENCY=4

RAG_DEFAULT_SCORE_THRESHOLD=0.25



MYSQL_URL=mysql+aiomysql://gestor:gestor_pass@localhost:3307/gestor_responsabilidades?charset=utf8mb4
# Si omites MYSQL_URL, Alembic usa el mismo valor por defecto (Compose local :3307).

# Migraciones: siempre manuales → alembic upgrade head (ver docs/MIGRATIONS.md)

MYSQL_POOL_PRE_PING=false



# Logging (INFO = consola limpia; DEBUG + OLLAMA_LOG_LLM_BODIES = depuración LLM)

APP_LOG_LEVEL=INFO

SCRAPER_LOG_LEVEL=INFO

OLLAMA_LOG_LLM_BODIES=false

SQLALCHEMY_LOG_ENGINE=false



# OCR (Sprint 1) — requiere Tesseract + Poppler en el host si no usas Docker

OCR_ENABLED=true

OCR_LANG=spa

OCR_DPI=200

OCR_MIN_CHARS_PER_PAGE=50



# Subida masiva

BULK_MAX_FILES=50

BULK_MAX_FILE_BYTES=52428800

BULK_INGEST_CONCURRENCY=2



# Chunking (Sprint 2) y análisis (Sprint 3)

DEFAULT_CHUNK_STRATEGY=adaptive

ANALYSIS_MAX_ITERATIONS=3

ANALYSIS_CONFIDENCE_THRESHOLD=0.55



# Scraper de normativa

SCRAPER_DEFAULT_PAIS=COLOMBIA

SCRAPER_SEARCH_PROVIDER=duckduckgo

SCRAPER_VALIDATION_MIN_CONFIDENCE=0.72

SCRAPER_MAX_CONCURRENCY=3



# JWT — autenticación (obligatorio en producción)

JWT_SECRET_KEY=cambiar-en-produccion-usar-secreto-largo-y-aleatorio

JWT_ALGORITHM=HS256

JWT_EXPIRE_MINUTES=1440



# Superadmin creado por migración Alembic (tabla roles + usuarios)

AUTH_BOOTSTRAP_ADMIN_EMAIL=superadmin@gestor.local

AUTH_BOOTSTRAP_ADMIN_PASSWORD=SuperAdmin123!

AUTH_BOOTSTRAP_ADMIN_NOMBRE=Super Administrador

AUTH_BOOTSTRAP_ADMIN_TERRITORIO=["COLOMBIA", null, null]

